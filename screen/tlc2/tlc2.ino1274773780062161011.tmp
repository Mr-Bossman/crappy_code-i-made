#include <spi4teensy3.h>

int pre= 360;
volatile uint16_t pwmbuffer[24];
uint32_t commands;
volatile uint64_t last = 0;
volatile unsigned int t = 0;
void time() {
uint64_t tmp = micros();
t = (tmp - last)/pre;
last = tmp;
}
void rite(){

    noInterrupts();
  for (uint8_t n = 0; n < 2; n++) {
    spi4teensy3::send(commands >> 24);
    spi4teensy3::send(commands >> 16);
    spi4teensy3::send(commands >> 8);
    spi4teensy3::send(commands);

    // 12 channels per TLC59711
    for (int8_t c = 11; c >= 0; c--) {
      // 16 bits per channel, send MSB first
     spi4teensy3::send(pwmbuffer[n * 12 + c] >> 8);
      spi4teensy3::send(pwmbuffer[n * 12 + c]);
    }
  }
    interrupts();
  //}
}

